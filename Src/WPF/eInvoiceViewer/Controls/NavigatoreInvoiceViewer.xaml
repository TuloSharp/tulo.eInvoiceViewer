<UserControl x:Class="tulo.eInvoiceViewer.Controls.NavigatoreInvoiceViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceViewer.Controls"
             xmlns:navType="clr-namespace:tulo.eInvoiceViewer.Utilities"
             xmlns:viewmodels="clr-namespace:tulo.eInvoiceViewer.ViewModels"
             xmlns:converters="clr-namespace:tulo.ResourcesWpfLib.Converters;assembly=tulo.ResourcesWpfLib"
             d:DesignHeight="1250"
             d:DesignWidth="130"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/tulo.ResourcesWpfLib;component/Resources/CommonResources.xaml" />
                <ResourceDictionary Source="pack://application:,,,/tulo.ResourcesWpfLib;component/Resources/SVGResources.xaml" />
                <ResourceDictionary Source="pack://application:,,,/tulo.ResourcesWpfLib;component/Resources/NavigationBarResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:EqualValueToParameterConverter x:Key="EqualValueToParameterConverter" />

            <Style x:Key="ModernNavButton" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#94A3B8" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Accent bar on the left  -->
                                <Rectangle x:Name="AccentBar"
                                           Grid.Column="0"
                                           Fill="Transparent"
                                           RadiusX="2"
                                           RadiusY="2" />

                                <!--  Button area – always transparent  -->
                                <Border x:Name="Bd"
                                        Grid.Column="1"
                                        Background="Transparent"
                                        CornerRadius="6"
                                        Padding="12,10"
                                        Margin="6,0,8,0">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </Grid>

                            <ControlTemplate.Triggers>

                                <!--  Hover → Text becomes lighter  -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="Orange" />
                                </Trigger>

                                <!--  Active → Text + blue emoji, accent bar visible  -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="AccentBar" Property="Fill" Value="{StaticResource ButtonIconPrimaryColorBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource ButtonIconPrimaryColorBrush}" />
                                </Trigger>

                                <!--  Active + Hover → stays blue  -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsChecked" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{StaticResource ButtonIconPrimaryColorBrush}" />
                                </MultiTrigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Background="{StaticResource BackgroundNavigatorBrushColor}"
                  RenderOptions.EdgeMode="Aliased">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  ── PDF Viewer ──  -->
                    <RadioButton Grid.Row="1"
                                 Style="{StaticResource ModernNavButton}"
                                 ToolTip="{Binding ToolTipPdfViewIcon}"
                                 Command="{Binding UpdateCurrentViewModelCommand}"
                                 CommandParameter="{x:Static navType:NavTypes.ContentXmlToPdfViewerView}"
                                 IsChecked="{Binding CurrentViewModel, Mode=OneWay, Converter={StaticResource EqualValueToParameterConverter}, ConverterParameter={x:Type viewmodels:ContentXmlToPdfViewerViewModel}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📄"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="{Binding NavLabelPdf}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <!--  ── About (down) ──  -->
                    <RadioButton Grid.Row="10"
                                 Style="{StaticResource ModernNavButton}"
                                 ToolTip="{Binding ToolTipAboutViewIcon}"
                                 Command="{Binding UpdateCurrentViewModelCommand}"
                                 CommandParameter="{x:Static navType:NavTypes.AboutView}"
                                 IsChecked="{Binding CurrentViewModel, Mode=OneWay, Converter={StaticResource EqualValueToParameterConverter}, ConverterParameter={x:Type viewmodels:AboutViewModel}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ℹ️"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="{Binding NavLabelAbout}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                </Grid>
            </Grid>
        </Grid>
    </Border>

</UserControl>
