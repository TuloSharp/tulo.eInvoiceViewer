<UserControl x:Class="tulo.eInvoiceViewer.Views.ContentXmlToPdfViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tulo.eInvoiceViewer.Views"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:controls="clr-namespace:tulo.eInvoiceViewer.Controls"
             xmlns:utilities="clr-namespace:tulo.ResourcesWpfLib.Utilities;assembly=tulo.ResourcesWpfLib"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid ToolTipService.ShowOnDisabled="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="AliceBlue">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="10" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="4" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="4" />
            </Grid.RowDefinitions>

            <Border Grid.Column="1"
                    Grid.Row="1"
                    CornerRadius="4"
                    Style="{StaticResource CustomBorderStyle}">
                <behaviors:Interaction.Behaviors>
                    <utilities:DropZoneBehavior DropCommand="{Binding FileDroppedCommand}" AllowedExtensions=".xml;.pdf" />
                </behaviors:Interaction.Behaviors>
                <TextBlock Text="{Binding DragAndDropText}"
                           ToolTip="{Binding ToolTipDragAndDrop}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="4" />
            </Border>

            <Button Name="OpenFileButton"
                    Grid.Column="3"
                    Grid.Row="1"
                    Command="{Binding SelectXmlFilePathCommand}"
                    ToolTip="{Binding ToolTipSelectFile}">
                <Grid>
                    <Viewbox Style="{StaticResource ViewBox4Icon}">
                        <Path Data="{StaticResource OpenInBrowserIconSVG}"
                              Style="{StaticResource ContentButtonPathStyle}"
                              Fill="{StaticResource ButtonBrushIconColor}"
                              Width="auto"
                              Height="auto" />
                    </Viewbox>
                </Grid>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <controls:PdfContentViewerControl Grid.Row="1" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="2" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="2" />
            </Grid.RowDefinitions>

            <Grid Visibility="{Binding HasMessage, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                  Grid.Column="1"
                  Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Path
                          Data="{StaticResource InfoIconSVG}"
                          Fill="{StaticResource InfoBrushColor}"
                          Width="24"
                          Height="24" />
                </Grid>

                <TextBlock Grid.Column="1"
                           FontWeight="Bold"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </Grid>
        </Grid>

    </Grid>
</UserControl>
